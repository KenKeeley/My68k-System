(module Power_Module (layer F.Cu) (tedit 0)
  (descr "Power Supply Module")
  (fp_text reference MH? (at 0 -4.445) (layer F.SilkS) hide
    (effects (font (size 1.524 1.016) (thickness 0.254)))
  )
  (fp_text value "Power Supply Module" (at -1.27 44.45 90) (layer F.SilkS) hide
    (effects (font (size 1.524 1.016) (thickness 0.254)))
  )
  (fp_circle (center 0 0) (end 3 0) (layer F.SilkS) (width 0.381))
  (fp_circle (center 0 88.9) (end 3 88.9) (layer F.SilkS) (width 0.381))
  (pad 1 thru_hole circle (at 0 0) (size 5 5) (drill 2.7) (layers *.Cu *.Mask))
  (pad 2 thru_hole circle (at 0 88.9) (size 5 5) (drill 2.7) (layers *.Cu *.Mask))
  (model ${MYLIBPATH}/My68k.3dshapes/Power_Module.wrl
    (at (xyz 0 0 0))
    (scale (xyz 1 1 1))
    (rotate (xyz 0 0 0))
  )
)
